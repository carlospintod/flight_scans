# Template for Streamlit Cloud secrets.
#
# Streamlit Cloud copies entries under [env] directly into os.environ
# at runtime — so the same code that reads from .env locally works
# unchanged on Streamlit Cloud.
#
# Set these in your Streamlit Cloud app's settings, NOT in this file:
#   https://share.streamlit.io/ → your app → Settings → Secrets
#
# Local development: copy this file to .streamlit/secrets.toml (gitignored)
# and replace the values. But for local dev, .env is simpler — only use
# secrets.toml if you want to test Streamlit Cloud behavior locally.

[env]
# API keys / tokens — same names as .env
SEARCHAPI_KEY = "sk_..."
RAPIDAPI_KEY = "..."
TRAVELPAYOUTS_TOKEN = "..."

# Turso (libSQL cloud SQLite) — gets your data persistence on
# Streamlit Cloud's ephemeral filesystem. Sign up free at turso.tech.
TURSO_DATABASE_URL = "libsql://your-db-name-yourgithubname.turso.io"
TURSO_AUTH_TOKEN = "..."

# Password gate for the deployed UI. Anyone with the Streamlit Cloud
# URL would otherwise be able to click 'Run everything' and burn your
# API quota. Set this to something only you know.
APP_PASSWORD = "pick-a-strong-passphrase"
